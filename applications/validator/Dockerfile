FROM rocker/r-ver:4.4.0 as deps

LABEL org.opencontainers.image.source https://github.com/phxplorer/phx_app

ENV RENV_PATHS_ROOT /renv
ENV RENV_PATHS_CACHE $RENV_PATHS_ROOT/cache
ENV RENV_PATHS_LIBRARY $RENV_PATHS_ROOT/library
WORKDIR /application

# Install system dependencies
# NOTE: the list was generated by `pak`
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
    curl \
    gnupg \
    zlib1g-dev \
    libgit2-dev \
    libssh2-1-dev \
    libssl-dev \
    libgeos-dev \
    libproj-dev \
    libsqlite3-dev \
    cmake \
    libicu-dev \
    libcurl4-openssl-dev \
    libxml2-dev \
    libudunits2-dev \
    pandoc \
    git \
    libgdal-dev \
    gdal-bin \
    libpng-dev \
    imagemagick \
    libmagick-dev \
    libhiredis-dev \
    unixodbc-dev && \
    rm -rf /var/lib/apt/lists/*

# Restore renv dependencies
COPY renv.lock .Rprofile ./
COPY renv renv
RUN R -e "renv::restore()"

# STAGE 2
FROM rocker/r-ver:4.4.0 as app
# FROM deps as app

ENV RENV_PATHS_ROOT /renv
ENV RENV_PATHS_CACHE $RENV_PATHS_ROOT/cache
ENV RENV_PATHS_LIBRARY $RENV_PATHS_ROOT/library
WORKDIR /application

# Copy built system & r libraries
# Potential optimization: try not to copy everything?
COPY --from=deps /usr/include /usr/include
COPY --from=deps /usr/lib /usr/lib
COPY --from=deps /usr/share /usr/share
COPY --from=deps $RENV_PATHS_LIBRARY $RENV_PATHS_LIBRARY

# Install MS SQL Server dependency
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl gnupg && \
    curl https://packages.microsoft.com/keys/microsoft.asc | apt-key add - && \
    curl https://packages.microsoft.com/config/ubuntu/22.04/prod.list > /etc/apt/sources.list.d/mssql-release.list && \
    apt-get update -qq && \
    ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 && \
    rm -rf /var/lib/apt/lists/*

# Copy project files - pay attention to .dockerignore
COPY . .

# Finishing the build
EXPOSE 3838
CMD bash
