linters:
  linters_with_defaults(
    line_length_linter = line_length_linter(100),
    object_usage_linter = NULL,  # Does not work with `box::use()`.
    object_name_linter = object_name_linter(styles = c("snake_case", "CamelCase", "UPPERCASE", "SNAKE_CASE")),
    cyclocomp_linter(complexity_limit = 50L)
  )
