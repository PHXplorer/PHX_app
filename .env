# WARNING: do not add sensitive information in this file
# To store environment secrets use `.env.local` or
# secrets management tool of the deployment platform.

#############################
### general configuration ###
#############################

WORKING_DIRECTORY=""
ENVIRONMENT=production
DOCKER_TAG=latest
DOCKER_BUILD=false
DOCKER_CREATE_DATABASE=false
ENSURE_DATA_ANONYMITY=true
USE_MOCK_DB_DATA=false

######################
### authentication ###
######################

SHINYPROXY_AUTH_METHOD=none
SHINYPROXY_ADMIN_GROUP="admins"
AUTH_ADMIN_GROUP="admins"
AUTH_REGULAR_GROUP="shiny_users"

# LDAP URI for ShinyProxy
LDAP_URI_SHINYPROXY="ldap://ldap_server/dc=ldapusermanager,dc=org"

# LDAP initial connection credentials
LDAP_ADMIN_DN="cn=admin,dc=ldapusermanager,dc=org"
LDAP_ADMIN_PASSWORD=admin

# Active Directory filtering patterns
AD_USER_SEARCH_FILTER="(sAMAccountName={0})"
AD_USER_SEARCH_BASE="ou=Users"
AD_GROUP_SEARCH_FILTER="(member={0})"
AD_GROUP_SEARCH_BASE="ou=Groups"

###########################
### database connection ###
###########################

# Which database are you going to use? Implemented drivers:
# - postgres
# - mssql
# - sqlite
DB_DRIVER=mssql

# ! IMPORTANT
# ! DO NOT DEFINE THESE CREDENTIALS HERE
# ! USE `.env.local` OR SECRETS MANAGEMENT TOOL OF THE DEPLOYMENT PLATFORM

# DB credentials required for the prod db environment (production application):
DB_HOST_PROD
DB_PORT_PROD
DB_NAME_PROD
DB_USER_PROD
DB_PASS_PROD

# DB credentials required for the dev db environment (dev application).
DB_HOST_DEV
DB_PORT_DEV
DB_NAME_DEV
DB_USER_DEV
DB_PASS_DEV

# DB credentials required for the synthetic data (dev application)
DB_HOST_SYNTHEA
DB_PORT_SYNTHEA
DB_NAME_SYNTHEA
DB_USER_SYNTHEA
DB_PASS_SYNTHEA

########################
### redis configuration ###
########################

REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_MAXMEMORY=1gb
REDIS_MAXMEMORY_POLICY=allkeys-lru
